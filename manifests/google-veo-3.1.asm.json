{
  "asm_version": "0.2",
  "service_id": "google/veo-3.1@3.1",
  "taxonomy": "ai.video.generation",
  "display_name": "Veo 3.1",
  "provider": {
    "name": "Google Cloud",
    "url": "https://cloud.google.com/vertex-ai",
    "verified_by": ["google-cloud-marketplace"]
  },
  "capabilities": {
    "description": "Text/image-to-video generation with optional audio output",
    "input_modalities": ["text", "image"],
    "output_modalities": ["video", "audio"]
  },
  "pricing": {
    "billing_dimensions": [
      {
        "dimension": "second",
        "unit": "per_1",
        "cost_per_unit": 0.20,
        "currency": "USD",
        "conditions": {
          "when": "resolution == '4k'",
          "cost_per_unit": 0.40
        }
      }
    ],
    "estimated": true
  },
  "quality": {
    "metrics": [
      {
        "name": "VBench_total",
        "score": 84.7,
        "scale": "0-100",
        "benchmark": "VBench",
        "self_reported": true
      }
    ]
  },
  "sla": {
    "latency_p50": "45s",
    "latency_p99": "120s",
    "regions": ["us-central1"]
  },
  "payment": {
    "methods": ["api_key_prepaid", "invoice"],
    "auth_type": "oauth2",
    "signup_url": "https://console.cloud.google.com"
  },
  "extensions": {
    "video_gen": {
      "max_duration": "8s",
      "resolutions": ["720p", "1080p", "4k"],
      "supports_audio": true,
      "supports_img2vid": true
    }
  }
}
