{
  "asm_version": "0.2",
  "service_id": "openai/tts-1@1.0",
  "taxonomy": "ai.audio.tts",
  "display_name": "OpenAI TTS",
  "provider": {
    "name": "OpenAI",
    "url": "https://openai.com",
    "verified_by": ["azure-marketplace"]
  },
  "capabilities": {
    "description": "Fast, affordable text-to-speech with 6 preset voices and streaming support",
    "input_modalities": ["text"],
    "output_modalities": ["audio"],
    "supported_languages": ["en", "zh", "ja", "ko", "fr", "de", "es", "pt", "ar", "hi"],
    "max_input_size": "4096 characters"
  },
  "pricing": {
    "billing_dimensions": [
      {
        "dimension": "character",
        "unit": "per_1M",
        "cost_per_unit": 15.00,
        "currency": "USD"
      }
    ]
  },
  "quality": {
    "metrics": [
      {
        "name": "MOS",
        "score": 4.0,
        "scale": "1-5",
        "benchmark": "Internal MOS evaluation",
        "self_reported": true
      }
    ]
  },
  "sla": {
    "latency_p50": "500ms",
    "latency_p99": "1.5s",
    "throughput": "50 req/min",
    "uptime": 0.999,
    "regions": ["us-east-1", "eu-west-1"]
  },
  "payment": {
    "methods": ["api_key_prepaid", "stripe"],
    "auth_type": "api_key",
    "signup_url": "https://platform.openai.com"
  },
  "extensions": {
    "tts": {
      "voice_count": 6,
      "supports_voice_cloning": false,
      "supports_streaming": true,
      "supports_ssml": false,
      "output_formats": ["mp3", "opus", "aac", "flac", "wav", "pcm"]
    }
  }
}
